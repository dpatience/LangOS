  "adjectives": {
    "_doc": "Kinyarwanda adjectives follow the noun and agree with its noun class via agreement prefixes. Comparatives use 'kuruta' (more than), superlatives use '-a bose/byose' (of all).",
    "position": "after",
    "agreement": "noun_class",
    "agreement_prefixes": {
      "1/2":   {"singular": "mu-",  "plural": "ba-"},
      "3/4":   {"singular": "mu-",  "plural": "mi-"},
      "5/6":   {"singular": "ri-",  "plural": "ma-"},
      "7/8":   {"singular": "ki-",  "plural": "bi-"},
      "9/10":  {"singular": "n-",   "plural": "n-"},
      "11/10": {"singular": "ru-",  "plural": "n-"},
      "12/13": {"singular": "ka-",  "plural": "tu-"},
      "14":    {"singular": "bu-"},
      "15":    {"singular": "ku-"},
      "16":    {"singular": "ha-"}
    },
    "comparative_marker": "kuruta",
    "superlative_marker": "cyane",
    "common": {
      "good":      {"root": "-nziza",    "surface": "nziza"},
      "bad":       {"root": "-mbi",      "surface": "mbi"},
      "big":       {"root": "-nini",     "surface": "nini"},
      "small":     {"root": "-to",       "surface": "to"},
      "new":       {"root": "-shya",     "surface": "shya"},
      "old":       {"root": "-shaje",    "surface": "shaje"},
