{
  "language": "rw",
  "script": "latin",
  "word_order": "SVO",
  "morphology": {
    "type": "agglutinative",
    "conjugation": "prefix",
    "prefix_key": "prefix",
    "default_prefix": "ara"
  },
  "sentence_rules": {
    "capitalize_first": true,
    "default_subject": null,
    "command_subject": null,
    "adjective_position": "after",
    "adverb_position": "after_verb",
    "copula_rules": {
      "1s": {"subject": null, "form": "ni"},
      "2s": {"subject": null, "form": "ni"},
      "3s": {"subject": null, "form": "ni"},
      "default": "ni"
    }
  },
  "elision": [
    {"before": "vowel", "token": "na", "replacement": "n'"}
  ],

  "nouns": {
    "_doc": "Kinyarwanda nouns use a noun class system (Bantu classes) with singular/plural prefix pairs. No articles exist. field_nouns maps machine field names to Kinyarwanda display forms.",
    "articles": {},
    "gender": "noun_class",
    "noun_classes": [
      {"class": "1/2",   "singular_prefix": "umu-", "plural_prefix": "aba-", "example_sg": "umuntu",   "example_pl": "abantu",   "semantic": "people"},
      {"class": "3/4",   "singular_prefix": "umu-", "plural_prefix": "imi-", "example_sg": "umugezi",  "example_pl": "imigezi",  "semantic": "plants, natural objects"},
      {"class": "5/6",   "singular_prefix": "i-",   "plural_prefix": "ama-", "example_sg": "ijambo",   "example_pl": "amajambo", "semantic": "augmentatives, paired things"},
      {"class": "7/8",   "singular_prefix": "iki-", "plural_prefix": "ibi-", "example_sg": "igitabo",  "example_pl": "ibitabo",  "semantic": "things, instruments"},
      {"class": "9/10",  "singular_prefix": "in-",  "plural_prefix": "in-",  "example_sg": "inka",     "example_pl": "inka",     "semantic": "animals, loanwords"},
      {"class": "11/10", "singular_prefix": "uru-", "plural_prefix": "in-",  "example_sg": "urukwavu", "example_pl": "inkwavu",  "semantic": "long/thin objects"},
      {"class": "12/13", "singular_prefix": "aka-", "plural_prefix": "utu-", "example_sg": "akana",    "example_pl": "utuwana",  "semantic": "diminutives"},
      {"class": "14",    "singular_prefix": "ubu-", "plural_prefix": null,   "example_sg": "ubuntu",   "example_pl": null,       "semantic": "abstract qualities"},
      {"class": "15",    "singular_prefix": "uku-", "plural_prefix": null,   "example_sg": "ukuboko",  "example_pl": null,       "semantic": "verbal nouns (infinitives)"},
      {"class": "16",    "singular_prefix": "aha-", "plural_prefix": null,   "example_sg": "ahantu",   "example_pl": null,       "semantic": "locative (specific place)"},
      {"class": "17",    "singular_prefix": "uku-", "plural_prefix": null,   "example_sg": "ukuntu",   "example_pl": null,       "semantic": "locative (indefinite)"},
      {"class": "18",    "singular_prefix": "mu-",  "plural_prefix": null,   "example_sg": "munzu",    "example_pl": null,       "semantic": "locative (inside)"}
    ],
    "plural_rules": [
      {"match": "^umu(.+)$", "replace": "aba$1",  "classes": ["1/2"]},
      {"match": "^umu(.+)$", "replace": "imi$1",  "classes": ["3/4"]},
      {"match": "^i(.+)$",   "replace": "ama$1",  "classes": ["5/6"]},
      {"match": "^iki(.+)$", "replace": "ibi$1",  "classes": ["7/8"]},
      {"match": "^uru(.+)$", "replace": "in$1",   "classes": ["11/10"]},
      {"match": "^aka(.+)$", "replace": "utu$1",  "classes": ["12/13"]}
    ],
    "field_nouns": {
      "age": "imyaka",
      "sex": "igitsina",
