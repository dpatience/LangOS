      "level": "urwego",
      "class": "ishuri",
      "school": "ishuri",
      "grade": "amanota"
    }
  },

  "pronouns": {
    "_doc": "Kinyarwanda pronouns: subject/object forms plus the verbal prefix used in agglutinative conjugation. Person codes: 1s/2s/3s/1p/2p/3p.",
    "REF_SPEAKER":          {"subject": "njye",   "object": "njye",   "prefix": "nda",  "person": "1s"},
    "REF_LISTENER":         {"subject": "wowe",   "object": "wowe",   "prefix": "ura",  "person": "2s"},
    "REF_PREVIOUS_ENTITY":  {"subject": "we",     "object": "we",     "prefix": "ara",  "person": "3s"},
