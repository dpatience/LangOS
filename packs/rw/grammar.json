      "slow":      {"root": "-buhoro",   "surface": "buhoro"},
      "long":      {"root": "-ndende",   "surface": "ndende"},
      "short":     {"root": "-gufi",     "surface": "gufi"},
      "important": {"root": "-komeye",   "surface": "ikomeye"},
      "beautiful": {"root": "-nziza",    "surface": "nziza cyane"},
      "correct":   {"root": "-kuri",     "surface": "ukuri"},
