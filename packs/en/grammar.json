  "intents": {
    "missing_fields": {
      "openers": {
        "neutral": ["Quick note:", "Before we continue:", "One thing left —"],
        "casual": ["Almost there —", "Nearly done —", "Just one more step:"],
        "formal": []
      },
      "recipes": [
        {"tones": ["formal"], "text": "could you please provide {fields_of}?"},
        {"tones": ["formal"], "text": "we require {fields_of} before we can continue."},
        {"tones": ["formal"], "text": "kindly share {fields_of} at your earliest convenience."},
        {"tones": ["neutral"], "text": "we still need {fields_of}."},
        {"tones": ["neutral"], "text": "{fields_of} {be} still missing."},
        {"tones": ["neutral"], "text": "to finish up, please add {fields_of}."},
        {"tones": ["neutral"], "text": "please share {fields_of} so we can move forward."},
        {"tones": ["casual"], "text": "we just need {fields_of}."},
        {"tones": ["casual"], "text": "can you send over {fields_of}?"},
        {"tones": ["casual"], "text": "mind adding {fields_of}?"}
      ]
    },
    "success": {
      "openers": {
        "neutral": ["All set —", "Done —"],
        "casual": ["Nice —", "Great —"],
        "formal": []
      },
      "recipes": [
        {"tones": ["formal"], "text": "{entity} has been successfully {action}."},
        {"tones": ["formal"], "text": "the operation completed: {entity} was {action}."},
        {"tones": ["neutral"], "text": "{entity} has been {action}."},
        {"tones": ["neutral"], "text": "{entity} was {action} successfully."},
        {"tones": ["casual"], "text": "{entity} is {action}!"},
        {"tones": ["casual"], "text": "got it — {entity} is {action}."}
      ]
    },
    "error": {
      "openers": {
        "neutral": [],
        "casual": ["Oops —", "Hmm —"],
        "formal": []
      },
      "recipes": [
        {"tones": ["formal"], "text": "an error occurred: {reason}."},
        {"tones": ["formal"], "text": "the operation could not be completed: {reason}."},
        {"tones": ["neutral"], "text": "something went wrong: {reason}."},
        {"tones": ["neutral"], "text": "that didn't work — {reason}."},
        {"tones": ["casual"], "text": "that didn't go as planned — {reason}."},
        {"tones": ["casual"], "text": "{reason} — let's try again?"}
      ]
    }
  },
