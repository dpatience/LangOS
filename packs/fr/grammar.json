{
  "language": "fr",
  "script": "latin",
  "word_order": "SVO",
  "morphology": {
    "type": "fusional",
    "conjugation": "lexical"
  },
  "sentence_rules": {
    "capitalize_first": true,
    "default_subject": "quelqu'un",
    "command_subject": null,
    "adjective_position": "after",
    "adverb_position": "after_verb",
    "copula_rules": {
      "1s": {"subject": "je", "form": "suis"},
      "2s": {"subject": "tu", "form": "es"},
      "3s": {"subject": null, "form": "est"},
      "1p": {"subject": "nous", "form": "sommes"},
      "2p": {"subject": "vous", "form": "êtes"},
      "3p": {"subject": null, "form": "sont"},
      "default": "est"
    }
  },
  "elision": [
    {"word": "je", "before": "vowel", "becomes": "j'"},
    {"word": "ne", "before": "vowel", "becomes": "n'"},
    {"word": "le", "before": "vowel", "becomes": "l'"},
    {"word": "la", "before": "vowel", "becomes": "l'"},
    {"word": "de", "before": "vowel", "becomes": "d'"},
    {"word": "que", "before": "vowel", "becomes": "qu'"},
    {"word": "se", "before": "vowel", "becomes": "s'"},
    {"word": "me", "before": "vowel", "becomes": "m'"},
    {"word": "te", "before": "vowel", "becomes": "t'"}
  ],

  "nouns": {
    "_doc": "French nouns: grammatical gender (masculine/feminine), plural with -s/-x, articles agree in gender/number. field_nouns maps machine field names to display forms with articles.",
    "articles": {
      "definite": {"masculine": "le", "feminine": "la", "plural": "les", "before_vowel": "l'"},
      "indefinite": {"masculine": "un", "feminine": "une", "plural": "des"},
      "partitive": {"masculine": "du", "feminine": "de la", "before_vowel": "de l'"}
    },
    "gender": "masculine_feminine",
    "plural_rules": [
      {"match": "(s|x|z)$", "replace": "$1"},
      {"match": "(eau|au)$", "replace": "$1x"},
      {"match": "al$", "replace": "aux"},
      {"match": "$", "replace": "s"}
    ],
    "uncountable": ["information", "connaissance", "conseil", "mobilier", "bagage", "progrès", "recherche", "logiciel", "temps", "équipement"],
    "field_nouns": {
      "age": {"display": "l'âge", "gender": "masculine"},
      "sex": {"display": "le sexe", "gender": "masculine"},
      "gender": {"display": "le genre", "gender": "masculine"},
      "residence": {"display": "la résidence", "gender": "feminine"},
      "language": {"display": "la langue", "gender": "feminine"},
      "name": {"display": "le nom", "gender": "masculine"},
      "first name": {"display": "le prénom", "gender": "masculine"},
      "last name": {"display": "le nom de famille", "gender": "masculine"},
      "email": {"display": "l'adresse e-mail", "gender": "feminine"},
      "phone": {"display": "le numéro de téléphone", "gender": "masculine"},
      "address": {"display": "l'adresse", "gender": "feminine"},
      "birth date": {"display": "la date de naissance", "gender": "feminine"},
      "nationality": {"display": "la nationalité", "gender": "feminine"},
      "occupation": {"display": "la profession", "gender": "feminine"},
      "level": {"display": "le niveau", "gender": "masculine"},
      "class": {"display": "la classe", "gender": "feminine"},
      "school": {"display": "l'école", "gender": "feminine"},
      "grade": {"display": "la note", "gender": "feminine"}
    }
  },

  "pronouns": {
    "_doc": "French pronouns: subject/object direct/object indirect/stressed/possessive forms with person keys.",
    "REF_SPEAKER":          {"subject": "je", "object": "me", "stressed": "moi", "possessive": "mon", "person": "1s"},
    "REF_LISTENER":         {"subject": "tu", "object": "te", "stressed": "toi", "possessive": "ton", "person": "2s"},
    "REF_PREVIOUS_ENTITY":  {"subject": "il", "object": "le", "stressed": "lui", "possessive": "son", "person": "3s"},
    "REF_HE":               {"subject": "il", "object": "le", "stressed": "lui", "possessive": "son", "person": "3s"},
    "REF_SHE":              {"subject": "elle", "object": "la", "stressed": "elle", "possessive": "sa", "person": "3s"},
    "REF_IT":               {"subject": "il", "object": "le", "stressed": "lui", "possessive": "son", "person": "3s"},
    "REF_WE":               {"subject": "nous", "object": "nous", "stressed": "nous", "possessive": "notre", "person": "1p"},
    "REF_THEY":             {"subject": "ils", "object": "les", "stressed": "eux", "possessive": "leur", "person": "3p"},
    "REF_HERE":             {"subject": "ici", "object": "ici"},
    "REF_TIME_NOW":         {"subject": "maintenant", "object": "maintenant"},
    "REF_TIME_PAST":        {"subject": "avant", "object": "avant"},
    "REF_TIME_FUTURE":      {"subject": "plus tard", "object": "plus tard"}
  },

