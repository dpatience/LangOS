  "prepositions": {
    "_doc": "French prepositions: placed before their object (dans la boîte, à l'école). Some contract with articles: à + le = au, de + le = du.",
    "container": "dans",
    "goal": "à",
    "source": "de",
    "beneficiary": "pour",
    "instrument": "avec",
    "location": "à",
    "time": "à",
    "direction": "vers",
    "about": "à propos de",
    "through": "à travers",
    "between": "entre",
    "without": "sans",
    "during": "pendant",
    "before": "avant",
    "after": "après",
    "contractions": {
      "à + le": "au",
      "à + les": "aux",
      "de + le": "du",
      "de + les": "des"
    }
  },

  "conjunctions": {
    "_doc": "French conjunctions: coordinating (et, ou, mais) connect equal items; subordinating (parce que, si, quand) introduce dependent clauses.",
