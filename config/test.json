{
  "runtime": {
    "name": "langos",
    "log_level": "debug"
  },
  "server": {
    "http": {
      "host": "127.0.0.1",
      "port": 9573
    },
    "grpc": {
      "enabled": true,
      "port": 9574
    }
  },
  "cache": {
    "l1": {
      "type": "memory",
      "max_entries": 1000
    },
    "l2": {
      "enabled": false
    }
  },
  "engines": {
    "rule": {
      "enabled": true,
      "patterns_dir": "packs/en/patterns"
    },
    "syntax": {
      "enabled": true
    },
    "stat": {
      "enabled": true,
      "model": "models/en/intent.json",
      "min_confidence": 0.3
    },
    "neural": {
      "enabled": true
    }
  },
  "routing": {
    "simple_command_max_tokens": 12,
    "simple_command_engine": "rule",
    "default_parse_engine": "neural",
    "default_generate_engine": "neural",
    "fallback_engine": "rule",
    "stages": {
      "parse": [
        "rule",
        "syntax",
        "stat",
        "neural"
      ],
      "generate": "neural"
    }
  },
  "documents": {
    "max_unit_concurrency": 4
  },
  "plugins": {
    "dir": "plugins",
    "installed": [
      "education-vocab"
    ]
  },
  "language_packs": {
    "installed": [
      "en",
      "fr",
      "rw",
      "tr"
    ],
    "default": "en"
  },
  "packs_dir": "packs"
}