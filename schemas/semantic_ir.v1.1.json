{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://langos.dev/schemas/semantic_ir.v1.1.json",
  "title": "LangOS Semantic IR v1.1",
  "description": "Language-independent intermediate representation. Nodes, not entities. Canonical predicates, not English verbs. Graph-first, JSON-export.",
  "type": "object",
  "required": ["version", "source", "units", "nodes", "references", "facts", "meta"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "const": "1.1"
    },
    "source": {
      "type": "object",
      "required": ["language", "text"],
      "additionalProperties": false,
      "properties": {
        "language": {
          "type": "string",
          "pattern": "^[a-z]{2}(-[A-Z]{2})?$"
        },
        "text": {
          "type": "string"
        }
      }
    },
    "units": {
      "type": "array",
      "items": { "$ref": "#/$defs/semantic_unit" }
    },
    "nodes": {
      "type": "array",
      "description": "Semantic nodes — everything extracted from text: named things, quantities, times, modifiers.",
      "items": { "$ref": "#/$defs/node" }
    },
    "references": {
      "type": "array",
      "items": { "$ref": "#/$defs/reference" }
    },
    "facts": {
      "type": "array",
      "items": { "$ref": "#/$defs/fact" }
    },
    "meta": {
      "type": "object",
      "required": ["detected_language", "engine"],
      "additionalProperties": true,
      "properties": {
        "detected_language": {
          "type": "string",
          "pattern": "^[a-z]{2}(-[A-Z]{2})?$"
        },
        "engine": { "$ref": "#/$defs/engine_info" },
        "latency_ms": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  },
  "$defs": {
    "semantic_unit": {
      "type": "object",
      "required": ["id", "type", "span", "predicate", "participants", "confidence"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Deterministic hash-based ID."
        },
        "type": {
          "type": "string",
          "enum": ["command", "question", "statement", "exclamation", "fragment"],
          "description": "Utterance type — basic linguistic classification."
        },
        "span": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "type": "integer", "minimum": 0 }
        },
        "predicate": {
          "type": "string",
          "pattern": "^[A-Z]+_[A-Z_]+$",
          "description": "Language-independent canonical predicate (ACTION_REGISTER, STATE_BE, QUERY_KNOW)."
        },
        "participants": {
          "type": "array",
          "items": { "$ref": "#/$defs/participant" }
        },
        "modifiers": {
          "type": "object",
          "additionalProperties": true
        },
        "confidence": { "$ref": "#/$defs/confidence_detail" }
      }
    },
    "participant": {
      "type": "object",
      "required": ["role", "node_id"],
      "additionalProperties": false,
      "properties": {
        "role": {
          "type": "string",
          "description": "Linguistic semantic role: patient, agent, theme, container, instrument, beneficiary, source, goal, experiencer, stimulus."
        },
        "node_id": {
          "type": "string",
          "description": "Points to a node in the nodes array."
        }
      }
    },
    "node": {
      "type": "object",
      "required": ["id", "surface", "kind"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Deterministic hash-based ID."
        },
        "surface": {
          "type": "string",
          "description": "Exact text as it appeared in input."
        },
        "canonical": {
          "type": "string",
          "description": "Normalized form (lowercased, lemmatized). May equal surface."
        },
        "kind": {
          "type": "string",
          "enum": ["named", "pronoun", "quantity", "time", "location", "modifier", "literal", "unknown"],
          "description": "What kind of thing this node represents — not domain type, just linguistic category."
        },
        "span": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "type": "integer", "minimum": 0 }
        },
        "ref": {
          "type": ["string", "null"],
          "description": "Reserved reference (REF_SPEAKER, REF_LISTENER, etc.) or null."
        }
      }
    },
    "reference": {
      "type": "object",
      "required": ["token", "ref", "confidence"],
      "additionalProperties": false,
      "properties": {
        "token": { "type": "string" },
        "ref": {
          "type": "string",
          "description": "REF_SPEAKER, REF_LISTENER, REF_PREVIOUS_ENTITY, REF_PREVIOUS_ACTION, REF_TIME_NOW, REF_HERE, or node ID."
        },
        "span": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "type": "integer", "minimum": 0 }
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "fact": {
      "type": "object",
      "required": ["subject_id", "predicate", "object"],
      "additionalProperties": false,
      "properties": {
        "subject_id": { "type": "string" },
        "predicate": { "type": "string" },
        "object": {},
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "confidence_detail": {
      "type": "object",
      "required": ["overall"],
      "additionalProperties": false,
      "properties": {
        "overall": { "type": "number", "minimum": 0, "maximum": 1 },
        "predicate": { "type": "number", "minimum": 0, "maximum": 1 },
        "roles": { "type": "number", "minimum": 0, "maximum": 1 },
        "references": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "engine_info": {
      "type": "object",
      "required": ["parser"],
      "additionalProperties": false,
      "properties": {
        "parser": { "type": "string" },
        "resolver": { "type": "string" },
        "generator": { "type": "string" },
        "language_pack": { "type": "string" },
        "version": { "type": "string" }
      }
    }
  }
}
