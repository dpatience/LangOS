{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://langos.dev/schemas/understand_request.v1.json",
  "title": "LangOS Understand Request v1.0",
  "type": "object",
  "required": ["text"],
  "additionalProperties": false,
  "properties": {
    "text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128000
    },
    "conversation": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "text"],
        "properties": {
          "role": { "type": "string", "enum": ["user", "assistant", "system"] },
          "text": { "type": "string" }
        }
      }
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "type": { "type": "string" }
        }
      }
    },
    "locale": {
      "type": "string",
      "pattern": "^[a-z]{2}(-[A-Z]{2})?$"
    },
    "options": {
      "type": "object",
      "properties": {
        "export_profile": { "type": "string", "default": "default" },
        "confidence_threshold": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
